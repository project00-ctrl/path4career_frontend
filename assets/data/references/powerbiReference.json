        { "property": "Excel", "desc": "Import from Excel workbooks", "version": "Get Data → Excel → Select file" },
        { "property": "CSV / Text", "desc": "Import delimited text files", "version": "Get Data → Text/CSV" },
        { "property": "SQL Server", "desc": "Connect to SQL Server databases", "version": "DirectQuery or Import mode" },
        { "property": "PostgreSQL", "desc": "Connect to PostgreSQL databases", "version": "Get Data → PostgreSQL database" },
        { "property": "MySQL", "desc": "Connect to MySQL databases", "version": "Get Data → MySQL database" },
        { "property": "Web", "desc": "Connect to web pages or REST APIs", "version": "Get Data → Web → Enter URL" },
        { "property": "SharePoint", "desc": "Connect to SharePoint lists and files", "version": "Get Data → SharePoint Online List" },
        { "property": "Azure SQL", "desc": "Connect to Azure SQL databases", "version": "Get Data → Azure SQL Database" },
        { "property": "OData", "desc": "Connect to OData feeds", "version": "Get Data → OData Feed" },
        { "property": "Dataflows", "desc": "Connect to Power BI dataflows", "version": "Reusable data prep in Power BI Service" },
        { "property": "Import Mode", "desc": "Load data into Power BI memory — fastest queries", "version": "Default mode for most sources" },
        { "property": "DirectQuery", "desc": "Query source directly — real-time but slower", "version": "Large datasets, Live databases" }
      ]
    },
    {
      "title": "Power Query (M Language)",
      "desc": "Data transformation in Power Query Editor using M language.",
      "type": "table",
      "columns": ["OPERATION", "DESCRIPTION", "EXAMPLE"],
      "rows": [
        { "property": "Remove Columns", "desc": "Delete unwanted columns from dataset", "version": "Right-click column → Remove" },
        { "property": "Rename Columns", "desc": "Rename columns for clarity", "version": "Double-click column header" },
        { "property": "Change Type", "desc": "Convert column data type", "version": "Text, Whole Number, Decimal, Date, etc." },
        { "property": "Filter Rows", "desc": "Remove rows that don't meet criteria", "version": "Column dropdown → Filter by value" },
        { "property": "Sort Rows", "desc": "Sort data by column values", "version": "Sort ascending / descending" },
        { "property": "Group By", "desc": "Aggregate rows by column values", "version": "Group By → Sum, Count, Average, etc." },
        { "property": "Merge Queries", "desc": "Join two tables (like SQL JOIN)", "version": "Left Outer, Inner, Full Outer join types" },
        { "property": "Append Queries", "desc": "Stack tables vertically (like UNION)", "version": "Append existing or new queries" },
        { "property": "Pivot Column", "desc": "Convert rows to columns", "version": "Select column → Pivot" },
        { "property": "Unpivot Columns", "desc": "Convert columns to rows", "version": "Select columns → Unpivot" },
        { "property": "Add Custom Column", "desc": "Create computed column with M formula", "version": "= [Price] * [Quantity]" },
        { "property": "Replace Values", "desc": "Replace specific values in a column", "version": "Replace null with 0" },
        { "property": "Split Column", "desc": "Split column by delimiter or position", "version": "Split by comma, space, etc." },
        { "property": "Close & Apply", "desc": "Save transformations and load data", "version": "Home → Close & Apply" }
      ]
    },
    {
      "title": "DAX Formulas",
      "desc": "Data Analysis Expressions for calculated columns and measures.",
      "type": "table",
      "columns": ["FUNCTION", "DESCRIPTION", "EXAMPLE"],
      "rows": [
        { "property": "SUM(column)", "desc": "Sum of a column", "version": "Total Sales = SUM(Sales[Amount])" },
        { "property": "AVERAGE(column)", "desc": "Average of a column", "version": "Avg Price = AVERAGE(Products[Price])" },
        { "property": "COUNT(column)", "desc": "Count non-blank values", "version": "Order Count = COUNT(Orders[OrderID])" },
        { "property": "COUNTROWS(table)", "desc": "Count rows in a table", "version": "Total Rows = COUNTROWS(Sales)" },
        { "property": "DISTINCTCOUNT(column)", "desc": "Count unique values", "version": "Unique Customers = DISTINCTCOUNT(Sales[CustomerID])" },
        { "property": "CALCULATE(expr, filter)", "desc": "Evaluate expression with modified filter context", "version": "US Sales = CALCULATE(SUM(Sales[Amount]), Sales[Country]=\"US\")" },
        { "property": "FILTER(table, condition)", "desc": "Return filtered table", "version": "FILTER(Products, Products[Price] > 100)" },
        { "property": "ALL(table/column)", "desc": "Remove filters from table/column", "version": "Total = CALCULATE(SUM(Sales[Amount]), ALL(Sales))" },
        { "property": "RELATED(column)", "desc": "Get value from related table", "version": "RELATED(Products[Category])" },
        { "property": "IF(condition, true, false)", "desc": "Conditional expression", "version": "Status = IF(Sales[Amount] > 1000, \"High\", \"Low\")" },
        { "property": "SWITCH(expr, val1, result1, ...)", "desc": "Multi-condition branching", "version": "SWITCH(Month, 1, \"Jan\", 2, \"Feb\", \"Other\")" },
        { "property": "FORMAT(value, format)", "desc": "Format value as text", "version": "FORMAT(Sales[Date], \"YYYY-MM\")" },
        { "property": "DIVIDE(num, denom, alt)", "desc": "Safe division (avoids divide by zero)", "version": "DIVIDE(Sales[Profit], Sales[Revenue], 0)" },
        { "property": "RANKX(table, expr)", "desc": "Rank values in a table", "version": "RANKX(ALL(Products), SUM(Sales[Amount]))" }
      ]
    },
    {
      "title": "DAX Time Intelligence",
      "desc": "Time-based calculations and comparisons.",
      "type": "table",
      "columns": ["FUNCTION", "DESCRIPTION", "EXAMPLE"],
      "rows": [
        { "property": "TOTALYTD(expr, date)", "desc": "Year-to-date total", "version": "YTD Sales = TOTALYTD(SUM(Sales[Amount]), Dates[Date])" },
        { "property": "TOTALQTD(expr, date)", "desc": "Quarter-to-date total", "version": "QTD Sales = TOTALQTD(SUM(Sales[Amount]), Dates[Date])" },
        { "property": "TOTALMTD(expr, date)", "desc": "Month-to-date total", "version": "MTD Sales = TOTALMTD(SUM(Sales[Amount]), Dates[Date])" },
        { "property": "SAMEPERIODLASTYEAR(dates)", "desc": "Same period in previous year", "version": "LY Sales = CALCULATE(SUM(Sales[Amount]), SAMEPERIODLASTYEAR(Dates[Date]))" },
        { "property": "DATEADD(dates, n, interval)", "desc": "Shift dates by n intervals", "version": "DATEADD(Dates[Date], -1, MONTH)" },
        { "property": "DATESYTD(dates)", "desc": "Returns year-to-date dates", "version": "CALCULATE(SUM(Sales[Amount]), DATESYTD(Dates[Date]))" },
        { "property": "PARALLELPERIOD(dates, n, interval)", "desc": "Parallel period shifted by n intervals", "version": "PARALLELPERIOD(Dates[Date], -1, YEAR)" },
        { "property": "PREVIOUSMONTH(dates)", "desc": "Dates in the previous month", "version": "CALCULATE(SUM(Sales[Amount]), PREVIOUSMONTH(Dates[Date]))" },
        { "property": "PREVIOUSYEAR(dates)", "desc": "Dates in the previous year", "version": "CALCULATE(SUM(Sales[Amount]), PREVIOUSYEAR(Dates[Date]))" },
        { "property": "Date Table (calendar)", "desc": "Dedicated date dimension table required for time intelligence", "version": "Dates = CALENDAR(DATE(2020,1,1), DATE(2025,12,31))" }
      ]
    },
