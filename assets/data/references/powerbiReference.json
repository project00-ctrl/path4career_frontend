        { "property": "Pie/Donut Chart", "desc": "Proportions of a whole (limited categories)", "version": "Market share, Budget allocation" },
        { "property": "Card", "desc": "Single large KPI number", "version": "Total revenue, Customer count" },
        { "property": "Table / Matrix", "desc": "Tabular data with drill-down", "version": "Detailed reports, Pivot-style views" },
        { "property": "Scatter Plot", "desc": "Relationship between two numeric values", "version": "Correlation analysis" },
        { "property": "Map", "desc": "Geographic data visualization", "version": "Sales by country/state" },
        { "property": "Gauge", "desc": "Progress toward a target", "version": "KPI vs target" },
        { "property": "Treemap", "desc": "Hierarchical data as nested rectangles", "version": "Category breakdown" },
        { "property": "Waterfall Chart", "desc": "Show incremental positive/negative changes", "version": "Profit breakdown, Budget variance" },
        { "property": "Funnel Chart", "desc": "Sequential stages with drop-off", "version": "Sales pipeline, Conversion rates" },
        { "property": "Slicer", "desc": "Interactive filter control for report users", "version": "Date range, Category selector" },
        { "property": "KPI Visual", "desc": "Key performance indicator with trend", "version": "Sales vs target with trend" }
      ]
