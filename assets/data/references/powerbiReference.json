      "rows": [
        { "property": "Report View", "desc": "Design canvas for creating interactive visualizations", "version": "Build dashboards, Add visuals, Format pages" },
        { "property": "Data View", "desc": "Table view of loaded data — inspect and edit", "version": "View raw data, Add columns, Change types" },
        { "property": "Model View", "desc": "Manage relationships between tables", "version": "Create joins, Set cardinality" },
        { "property": "Fields Pane", "desc": "List of tables, columns, and measures", "version": "Drag fields to visuals" },
        { "property": "Visualizations Pane", "desc": "Choose and configure chart types", "version": "Bar, Line, Pie, Table, Card, etc." },
        { "property": "Filters Pane", "desc": "Apply filters at visual, page, or report level", "version": "Filter by date, category, value" },
        { "property": "Format Pane", "desc": "Customize visual appearance — colors, fonts, axes", "version": "Titles, Labels, Legends, Data colors" },
        { "property": "Bookmarks", "desc": "Save report state for navigation and storytelling", "version": "Toggle between views" },
        { "property": "Drill Through", "desc": "Navigate to detail page by right-clicking data point", "version": "Click product → see detailed sales" },
        { "property": "Sync Slicers", "desc": "Synchronize slicer selections across pages", "version": "Date slicer applies to all pages" }
      ]
