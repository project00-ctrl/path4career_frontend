        { "property": "@app.on_event('startup')", "desc": "Run code on application startup", "version": "@app.on_event('startup') async def startup():" },
        { "property": "Middleware", "desc": "Custom request/response middleware", "version": "@app.middleware('http') async def add_headers(req, call_next):" },
        { "property": "Auto docs (/docs)", "desc": "Swagger UI auto-generated API documentation", "version": "http://localhost:8000/docs" },
        { "property": "Redoc (/redoc)", "desc": "ReDoc alternative API documentation", "version": "http://localhost:8000/redoc" }
