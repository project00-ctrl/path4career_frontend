    {
      "title": "CLI & Deployment",
      "desc": "Running, testing, and deploying FastAPI applications.",
      "type": "table",
      "columns": ["COMMAND", "DESCRIPTION", "EXAMPLE"],
      "rows": [
        { "property": "pip install fastapi[all]", "desc": "Install FastAPI with all dependencies", "version": "pip install fastapi[all]" },
        { "property": "uvicorn main:app --reload", "desc": "Start development server with hot reload", "version": "uvicorn main:app --reload --port 8000" },
        { "property": "uvicorn main:app --workers 4", "desc": "Start production server with multiple workers", "version": "uvicorn main:app --host 0.0.0.0 --workers 4" },
        { "property": "gunicorn -k uvicorn.workers.UvicornWorker", "desc": "Production ASGI server", "version": "gunicorn main:app -k uvicorn.workers.UvicornWorker" },
        { "property": "pytest", "desc": "Run tests", "version": "pytest tests/ -v" },
        { "property": "TestClient(app)", "desc": "Test client for API testing", "version": "client = TestClient(app); response = client.get('/users')" },
        { "property": "httpx.AsyncClient", "desc": "Async test client", "version": "async with AsyncClient(app=app) as client:" },
