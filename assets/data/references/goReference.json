    {
      "title": "CLI & Module Commands",
      "desc": "Go toolchain commands for building and managing projects.",
      "type": "table",
      "columns": ["COMMAND", "DESCRIPTION", "EXAMPLE"],
      "rows": [
        { "property": "go mod init module", "desc": "Initialize a new Go module", "version": "go mod init github.com/user/project" },
