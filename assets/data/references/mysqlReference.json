{
  "sections": [
    {
      "id": "data-types",
      "title": "Data Types",
      "type": "table",
      "columns": ["TYPE", "DESCRIPTION", "STORAGE"],
      "rows": [
        { "property": "TINYINT", "desc": "Very small integer", "version": "1 byte (−128 to 127)" },
        { "property": "SMALLINT", "desc": "Small integer", "version": "2 bytes (−32,768 to 32,767)" },
        { "property": "MEDIUMINT", "desc": "Medium integer", "version": "3 bytes (±8 million)" },
        { "property": "INT / INTEGER", "desc": "Standard integer", "version": "4 bytes (±2.1 billion)" },
        { "property": "BIGINT", "desc": "Large integer", "version": "8 bytes (±9.2 quintillion)" },
        { "property": "FLOAT", "desc": "Single-precision floating point", "version": "4 bytes" },
        { "property": "DOUBLE", "desc": "Double-precision floating point", "version": "8 bytes" },
        { "property": "DECIMAL(M,D)", "desc": "Exact decimal with M digits, D decimal places", "version": "Variable (max 65 digits)" },
        { "property": "BIT(M)", "desc": "Bit-field type storing M bits", "version": "1–8 bytes" },
        { "property": "CHAR(M)", "desc": "Fixed-length string (padded with spaces)", "version": "0–255 characters" },
        { "property": "VARCHAR(M)", "desc": "Variable-length string", "version": "0–65,535 characters" },
        { "property": "TINYTEXT", "desc": "Short text", "version": "Max 255 bytes" },
        { "property": "TEXT", "desc": "Standard text", "version": "Max 65,535 bytes" },
        { "property": "MEDIUMTEXT", "desc": "Medium text", "version": "Max 16 MB" },
        { "property": "LONGTEXT", "desc": "Large text", "version": "Max 4 GB" },
        { "property": "BINARY(M)", "desc": "Fixed-length binary string", "version": "0–255 bytes" },
        { "property": "VARBINARY(M)", "desc": "Variable-length binary string", "version": "0–65,535 bytes" },
        { "property": "TINYBLOB", "desc": "Short binary large object", "version": "Max 255 bytes" },
        { "property": "BLOB", "desc": "Standard binary large object", "version": "Max 65,535 bytes" },
        { "property": "MEDIUMBLOB", "desc": "Medium binary large object", "version": "Max 16 MB" },
        { "property": "LONGBLOB", "desc": "Large binary large object", "version": "Max 4 GB" },
        { "property": "DATE", "desc": "Date in YYYY-MM-DD format", "version": "3 bytes" },
        { "property": "TIME", "desc": "Time in HH:MM:SS format", "version": "3 bytes" },
        { "property": "DATETIME", "desc": "Date and time combined", "version": "8 bytes" },
        { "property": "TIMESTAMP", "desc": "Date/time stored as Unix timestamp", "version": "4 bytes (1970–2038)" },
        { "property": "YEAR", "desc": "Year in YYYY format", "version": "1 byte (1901–2155)" },
        { "property": "ENUM('a','b',...)", "desc": "String from predefined list", "version": "1–2 bytes (max 65,535 values)" },
        { "property": "SET('a','b',...)", "desc": "Set of zero or more values from list", "version": "1–8 bytes (max 64 members)" },
        { "property": "JSON", "desc": "JSON formatted data (MySQL 5.7+)", "version": "Max ~4 GB" },
        { "property": "GEOMETRY", "desc": "Spatial data type for geographic data", "version": "Variable" }
      ]
    },
    {
      "id": "string-functions",
      "title": "String Functions",
      "type": "table",
      "columns": ["FUNCTION", "DESCRIPTION", "EXAMPLE"],
      "rows": [
        { "property": "CONCAT(s1, s2, ...)", "desc": "Concatenates strings", "version": "CONCAT('Hello', ' ', 'World')" },
        { "property": "CONCAT_WS(sep, s1, s2)", "desc": "Concatenates with separator", "version": "CONCAT_WS('-', '2024', '01', '15')" },
        { "property": "LENGTH(str)", "desc": "Returns length in bytes", "version": "LENGTH('Hello') → 5" },
        { "property": "CHAR_LENGTH(str)", "desc": "Returns length in characters", "version": "CHAR_LENGTH('日本') → 2" },
        { "property": "UPPER(str) / UCASE(str)", "desc": "Converts to uppercase", "version": "UPPER('hello') → 'HELLO'" },
        { "property": "LOWER(str) / LCASE(str)", "desc": "Converts to lowercase", "version": "LOWER('HELLO') → 'hello'" },
        { "property": "TRIM(str)", "desc": "Removes leading and trailing spaces", "version": "TRIM('  hi  ') → 'hi'" },
        { "property": "LTRIM(str) / RTRIM(str)", "desc": "Removes leading or trailing spaces", "version": "LTRIM('  hi') → 'hi'" },
        { "property": "SUBSTRING(str, pos, len)", "desc": "Extracts substring", "version": "SUBSTRING('Hello', 2, 3) → 'ell'" },
        { "property": "LEFT(str, n) / RIGHT(str, n)", "desc": "Returns leftmost or rightmost n chars", "version": "LEFT('Hello', 3) → 'Hel'" },
        { "property": "REPLACE(str, from, to)", "desc": "Replaces occurrences", "version": "REPLACE('abc', 'b', 'x') → 'axc'" },
        { "property": "REVERSE(str)", "desc": "Reverses string", "version": "REVERSE('Hello') → 'olleH'" },
        { "property": "REPEAT(str, n)", "desc": "Repeats string n times", "version": "REPEAT('ab', 3) → 'ababab'" },
        { "property": "LPAD(str, len, pad)", "desc": "Left-pads to length", "version": "LPAD('5', 3, '0') → '005'" },
        { "property": "RPAD(str, len, pad)", "desc": "Right-pads to length", "version": "RPAD('hi', 5, '.') → 'hi...'" },
        { "property": "LOCATE(sub, str)", "desc": "Returns position of first occurrence", "version": "LOCATE('lo', 'Hello') → 4" },
        { "property": "INSERT(str, pos, len, newstr)", "desc": "Inserts string at position", "version": "INSERT('Hello', 2, 3, 'xyz')" },
        { "property": "FORMAT(num, decimals)", "desc": "Formats number with commas", "version": "FORMAT(1234567.89, 2) → '1,234,567.89'" },
        { "property": "HEX(str) / UNHEX(str)", "desc": "Converts to/from hexadecimal", "version": "HEX('A') → '41'" },
        { "property": "ASCII(str)", "desc": "Returns ASCII value of first character", "version": "ASCII('A') → 65" }
      ]
    },
    {
      "id": "numeric-functions",
      "title": "Numeric Functions",
      "type": "table",
      "columns": ["FUNCTION", "DESCRIPTION", "EXAMPLE"],
      "rows": [
        { "property": "ABS(x)", "desc": "Returns absolute value", "version": "ABS(-5) → 5" },
        { "property": "CEIL(x) / CEILING(x)", "desc": "Rounds up to nearest integer", "version": "CEIL(4.2) → 5" },
        { "property": "FLOOR(x)", "desc": "Rounds down to nearest integer", "version": "FLOOR(4.9) → 4" },
        { "property": "ROUND(x, d)", "desc": "Rounds to d decimal places", "version": "ROUND(3.456, 2) → 3.46" },
        { "property": "TRUNCATE(x, d)", "desc": "Truncates to d decimal places (no rounding)", "version": "TRUNCATE(3.456, 2) → 3.45" },
        { "property": "MOD(x, y)", "desc": "Returns remainder of x/y", "version": "MOD(10, 3) → 1" },
        { "property": "POW(x, y) / POWER(x, y)", "desc": "Returns x raised to power y", "version": "POW(2, 3) → 8" },
        { "property": "SQRT(x)", "desc": "Returns square root", "version": "SQRT(16) → 4" },
        { "property": "RAND()", "desc": "Returns random float between 0 and 1", "version": "RAND()" },
        { "property": "SIGN(x)", "desc": "Returns sign: −1, 0, or 1", "version": "SIGN(-5) → −1" },
        { "property": "GREATEST(v1, v2, ...)", "desc": "Returns largest value from list", "version": "GREATEST(1, 5, 3) → 5" },
        { "property": "LEAST(v1, v2, ...)", "desc": "Returns smallest value from list", "version": "LEAST(1, 5, 3) → 1" },
        { "property": "LOG(x) / LN(x)", "desc": "Returns natural logarithm", "version": "LOG(2.718) → 1" },
        { "property": "LOG10(x)", "desc": "Returns base-10 logarithm", "version": "LOG10(100) → 2" },
        { "property": "LOG2(x)", "desc": "Returns base-2 logarithm", "version": "LOG2(8) → 3" },
        { "property": "EXP(x)", "desc": "Returns e raised to power x", "version": "EXP(1) → 2.718..." },
        { "property": "PI()", "desc": "Returns value of Pi", "version": "PI() → 3.141592..." },
        { "property": "CONV(n, from, to)", "desc": "Converts number between bases", "version": "CONV('ff', 16, 10) → '255'" }
      ]
    },
    {
      "id": "date-functions",
      "title": "Date & Time Functions",
      "type": "table",
      "columns": ["FUNCTION", "DESCRIPTION", "EXAMPLE"],
      "rows": [
        { "property": "NOW()", "desc": "Returns current date and time", "version": "NOW() → '2024-01-15 12:30:00'" },
        { "property": "CURDATE() / CURRENT_DATE()", "desc": "Returns current date", "version": "CURDATE() → '2024-01-15'" },
        { "property": "CURTIME() / CURRENT_TIME()", "desc": "Returns current time", "version": "CURTIME() → '12:30:00'" },
        { "property": "YEAR(date)", "desc": "Extracts year", "version": "YEAR(NOW()) → 2024" },
        { "property": "MONTH(date)", "desc": "Extracts month (1–12)", "version": "MONTH(NOW()) → 1" },
        { "property": "DAY(date) / DAYOFMONTH(date)", "desc": "Extracts day of month (1–31)", "version": "DAY(NOW()) → 15" },
        { "property": "HOUR(time) / MINUTE(time) / SECOND(time)", "desc": "Extracts time component", "version": "HOUR(NOW()) → 12" },
        { "property": "DAYNAME(date)", "desc": "Returns day name", "version": "DAYNAME(NOW()) → 'Monday'" },
        { "property": "MONTHNAME(date)", "desc": "Returns month name", "version": "MONTHNAME(NOW()) → 'January'" },
        { "property": "DAYOFWEEK(date)", "desc": "Returns day of week (1=Sun, 7=Sat)", "version": "DAYOFWEEK(NOW())" },
        { "property": "DAYOFYEAR(date)", "desc": "Returns day of year (1–366)", "version": "DAYOFYEAR(NOW())" },
        { "property": "WEEK(date)", "desc": "Returns week number (0–53)", "version": "WEEK(NOW())" },
        { "property": "DATE_ADD(date, INTERVAL n unit)", "desc": "Adds interval to date", "version": "DATE_ADD(NOW(), INTERVAL 7 DAY)" },
        { "property": "DATE_SUB(date, INTERVAL n unit)", "desc": "Subtracts interval from date", "version": "DATE_SUB(NOW(), INTERVAL 1 MONTH)" },
        { "property": "DATEDIFF(d1, d2)", "desc": "Returns difference in days", "version": "DATEDIFF('2024-12-31', '2024-01-01') → 365" },
        { "property": "TIMESTAMPDIFF(unit, d1, d2)", "desc": "Returns difference in specified unit", "version": "TIMESTAMPDIFF(MONTH, '2024-01-01', NOW())" },
        { "property": "DATE_FORMAT(date, fmt)", "desc": "Formats date as string", "version": "DATE_FORMAT(NOW(), '%d/%m/%Y')" },
        { "property": "STR_TO_DATE(str, fmt)", "desc": "Parses string to date", "version": "STR_TO_DATE('15-01-2024', '%d-%m-%Y')" },
        { "property": "UNIX_TIMESTAMP(date)", "desc": "Returns Unix timestamp", "version": "UNIX_TIMESTAMP(NOW())" },
        { "property": "FROM_UNIXTIME(ts)", "desc": "Converts Unix timestamp to datetime", "version": "FROM_UNIXTIME(1705334400)" },
        { "property": "LAST_DAY(date)", "desc": "Returns last day of month", "version": "LAST_DAY('2024-02-15') → '2024-02-29'" }
      ]
    },
    {
      "id": "json-functions",
      "title": "JSON Functions",
      "type": "table",
      "columns": ["FUNCTION", "DESCRIPTION", "EXAMPLE"],
      "rows": [
        { "property": "JSON_OBJECT(key, val, ...)", "desc": "Creates JSON object", "version": "JSON_OBJECT('name', 'Dev', 'age', 25)" },
        { "property": "JSON_ARRAY(v1, v2, ...)", "desc": "Creates JSON array", "version": "JSON_ARRAY(1, 'two', null)" },
        { "property": "JSON_EXTRACT(doc, path)", "desc": "Extracts value at JSON path", "version": "JSON_EXTRACT(data, '$.name')" },
        { "property": "column->path", "desc": "Shorthand for JSON_EXTRACT", "version": "data->'$.name'" },
        { "property": "column->>path", "desc": "Extracts and unquotes JSON value", "version": "data->>'$.name'" },
        { "property": "JSON_SET(doc, path, val)", "desc": "Sets value at path (creates if missing)", "version": "JSON_SET(data, '$.age', 26)" },
        { "property": "JSON_INSERT(doc, path, val)", "desc": "Inserts value only if path doesn't exist", "version": "JSON_INSERT(data, '$.email', 'a@b.com')" },
        { "property": "JSON_REPLACE(doc, path, val)", "desc": "Replaces value only if path exists", "version": "JSON_REPLACE(data, '$.name', 'NewName')" },
        { "property": "JSON_REMOVE(doc, path)", "desc": "Removes value at path", "version": "JSON_REMOVE(data, '$.temp')" },
        { "property": "JSON_CONTAINS(doc, val)", "desc": "Checks if document contains value", "version": "JSON_CONTAINS(data, '\"Dev\"', '$.name')" },
        { "property": "JSON_TYPE(val)", "desc": "Returns type of JSON value", "version": "JSON_TYPE(data->'$.name')" },
        { "property": "JSON_VALID(str)", "desc": "Checks if string is valid JSON", "version": "JSON_VALID('{\"a\":1}') → 1" },
        { "property": "JSON_LENGTH(doc)", "desc": "Number of elements in JSON array/object", "version": "JSON_LENGTH(data->'$.tags')" },
        { "property": "JSON_KEYS(doc)", "desc": "Returns keys of JSON object", "version": "JSON_KEYS(data)" },
        { "property": "JSON_ARRAYAGG(col)", "desc": "Aggregates values into JSON array", "version": "SELECT JSON_ARRAYAGG(name) FROM users" },
        { "property": "JSON_OBJECTAGG(key, val)", "desc": "Aggregates key-value pairs into JSON object", "version": "SELECT JSON_OBJECTAGG(name, age) FROM users" }
      ]
    },
    {
      "id": "admin-commands",
      "title": "Administration Commands",
      "type": "table",
      "columns": ["COMMAND", "DESCRIPTION", "EXAMPLE"],
      "rows": [
        { "property": "SHOW DATABASES", "desc": "Lists all databases", "version": "SHOW DATABASES;" },
        { "property": "USE database", "desc": "Switches to a database", "version": "USE mydb;" },
        { "property": "SHOW TABLES", "desc": "Lists tables in current database", "version": "SHOW TABLES;" },
        { "property": "DESCRIBE table", "desc": "Shows table structure (columns, types)", "version": "DESCRIBE users;" },
        { "property": "SHOW COLUMNS FROM table", "desc": "Detailed column information", "version": "SHOW COLUMNS FROM users;" },
        { "property": "SHOW CREATE TABLE table", "desc": "Shows CREATE TABLE statement", "version": "SHOW CREATE TABLE users;" },
        { "property": "SHOW INDEX FROM table", "desc": "Shows indexes on a table", "version": "SHOW INDEX FROM users;" },
        { "property": "SHOW PROCESSLIST", "desc": "Lists active MySQL connections/queries", "version": "SHOW PROCESSLIST;" },
        { "property": "SHOW STATUS", "desc": "Shows server status variables", "version": "SHOW STATUS LIKE 'Threads%';" },
        { "property": "SHOW VARIABLES", "desc": "Shows server system variables", "version": "SHOW VARIABLES LIKE 'max_connections';" },
        { "property": "EXPLAIN query", "desc": "Shows query execution plan", "version": "EXPLAIN SELECT * FROM users WHERE id=1;" },
        { "property": "OPTIMIZE TABLE", "desc": "Reclaims unused space and defragments", "version": "OPTIMIZE TABLE users;" },
        { "property": "CHECK TABLE", "desc": "Checks table for errors", "version": "CHECK TABLE users;" },
        { "property": "REPAIR TABLE", "desc": "Repairs a corrupted table", "version": "REPAIR TABLE users;" },
        { "property": "FLUSH PRIVILEGES", "desc": "Reloads grant tables", "version": "FLUSH PRIVILEGES;" },
        { "property": "FLUSH TABLES", "desc": "Closes all open tables", "version": "FLUSH TABLES;" },
        { "property": "SET GLOBAL var = val", "desc": "Sets global server variable", "version": "SET GLOBAL max_connections = 500;" },
        { "property": "KILL connection_id", "desc": "Terminates a connection", "version": "KILL 42;" }
      ]
    },
    {
      "id": "stored-procedures",
      "title": "Stored Procedures & Functions",
      "type": "table",
      "columns": ["STATEMENT", "DESCRIPTION", "EXAMPLE"],
      "rows": [
        { "property": "CREATE PROCEDURE", "desc": "Creates a stored procedure", "version": "CREATE PROCEDURE GetUsers() BEGIN SELECT * FROM users; END;" },
        { "property": "CALL procedure()", "desc": "Executes a stored procedure", "version": "CALL GetUsers();" },
        { "property": "DROP PROCEDURE", "desc": "Deletes a stored procedure", "version": "DROP PROCEDURE IF EXISTS GetUsers;" },
        { "property": "IN parameter", "desc": "Input parameter (read-only)", "version": "CREATE PROCEDURE Get(IN id INT) ..." },
        { "property": "OUT parameter", "desc": "Output parameter (returns value)", "version": "CREATE PROCEDURE Count(OUT total INT) ..." },
        { "property": "INOUT parameter", "desc": "Both input and output", "version": "CREATE PROCEDURE Inc(INOUT val INT) ..." },
        { "property": "DECLARE var type", "desc": "Declares a local variable", "version": "DECLARE counter INT DEFAULT 0;" },
        { "property": "SET var = expr", "desc": "Assigns value to variable", "version": "SET counter = counter + 1;" },
        { "property": "IF...THEN...END IF", "desc": "Conditional logic in procedures", "version": "IF x > 0 THEN ... END IF;" },
        { "property": "WHILE...DO...END WHILE", "desc": "Loop in procedures", "version": "WHILE i < 10 DO ... END WHILE;" },
        { "property": "CURSOR", "desc": "Iterates through query results row by row", "version": "DECLARE cur CURSOR FOR SELECT ..." },
        { "property": "CREATE FUNCTION", "desc": "Creates a stored function (returns value)", "version": "CREATE FUNCTION Add(a INT, b INT) RETURNS INT ..." },
        { "property": "CREATE TRIGGER", "desc": "Creates trigger on INSERT/UPDATE/DELETE", "version": "CREATE TRIGGER log AFTER INSERT ON users ..." },
        { "property": "CREATE EVENT", "desc": "Creates scheduled event", "version": "CREATE EVENT cleanup ON SCHEDULE ... DO ..." }
      ]
    },
    {
      "id": "backup-import",
      "title": "Backup & Import",
      "type": "table",
      "columns": ["COMMAND", "DESCRIPTION", "EXAMPLE"],
      "rows": [
        { "property": "mysqldump", "desc": "Creates SQL dump of database", "version": "mysqldump -u root -p mydb > backup.sql" },
        { "property": "mysqldump --all-databases", "desc": "Dumps all databases", "version": "mysqldump -u root -p --all-databases > all.sql" },
        { "property": "mysqldump --tables", "desc": "Dumps specific tables", "version": "mysqldump -u root -p mydb users orders > tables.sql" },
        { "property": "mysql < file.sql", "desc": "Imports SQL dump file", "version": "mysql -u root -p mydb < backup.sql" },
        { "property": "SOURCE file.sql", "desc": "Runs SQL file from mysql client", "version": "SOURCE /path/to/backup.sql;" },
        { "property": "LOAD DATA INFILE", "desc": "Imports CSV/text file into table", "version": "LOAD DATA INFILE 'data.csv' INTO TABLE users FIELDS TERMINATED BY ',';" },
        { "property": "SELECT INTO OUTFILE", "desc": "Exports query results to file", "version": "SELECT * INTO OUTFILE '/tmp/users.csv' FROM users;" },
        { "property": "mysqlimport", "desc": "Command-line data import utility", "version": "mysqlimport -u root -p mydb data.txt" }
      ]
    }
  ]
}
