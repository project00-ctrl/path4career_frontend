        {
            "id": 1,
            "title": "Container",
            "difficulty": "basic",
            "description": "Create a Bootstrap <code>.container</code> with a <code>&lt;h1&gt;</code> that says <strong>Hello Bootstrap!</strong>.",
            "starterCode": "<!-- Use Bootstrap container -->\n<div>\n  <h1>Hello Bootstrap!</h1>\n</div>",
            "expectedOutput": "",
            "validationType": "containsAll",
            "validationValue": [
                "container",
                "Hello Bootstrap!"
            ],
            "hint": "Add class=\"container\" to the div.",
            "solutionCode": "<div class=\"container\">\n  <h1 class=\"text-center\">Bootstrap Page</h1>\n</div>"
        },
        {
            "id": 2,
            "title": "Buttons",
            "difficulty": "basic",
            "description": "Create two buttons using <code>btn btn-primary</code> and <code>btn btn-danger</code> classes.",
            "starterCode": "<!-- Create Bootstrap buttons -->\n<button>Primary</button>\n<button>Danger</button>",
            "expectedOutput": "",
            "validationType": "containsAll",
            "validationValue": [
                "btn-primary",
                "btn-danger"
            ],
            "hint": "Add class=\"btn btn-primary\" and class=\"btn btn-danger\".",
            "solutionCode": "<button class=\"btn btn-primary\">Click Me</button>"
        },
        {
            "id": 3,
            "title": "Alert Box",
            "difficulty": "basic",
            "description": "Create a success alert using <code>alert alert-success</code> with the text <strong>Operation completed!</strong>.",
            "starterCode": "<!-- Create an alert -->\n<div>Operation completed!</div>",
            "expectedOutput": "",
            "validationType": "containsAll",
            "validationValue": [
                "alert-success",
                "Operation completed!"
            ],
            "hint": "Add class=\"alert alert-success\" to the div.",
            "solutionCode": "<div class=\"alert alert-success\">Success!</div>"
        },
        {
            "id": 4,
            "title": "Grid System",
            "difficulty": "basic",
            "description": "Create a row with two equal columns using <code>col-6</code>. Put <strong>Left</strong> and <strong>Right</strong> in them.",
            "starterCode": "<!-- Create a 2-column grid -->\n<div class=\"row\">\n  <div>Left</div>\n  <div>Right</div>\n</div>",
            "expectedOutput": "",
            "validationType": "containsAll",
            "validationValue": [
                "row",
                "col-6",
                "Left",
                "Right"
            ],
            "hint": "Add class=\"col-6\" to each inner div.",
            "solutionCode": "<div class=\"card\">\n  <div class=\"card-body\">Card Content</div>\n</div>"
        },
        {
            "id": 5,
            "title": "Card Component",
            "difficulty": "basic",
            "description": "Create a Bootstrap <code>.card</code> with a <code>.card-body</code> containing a <code>.card-title</code> saying <strong>My Card</strong>.",
            "starterCode": "<!-- Create a card -->\n<div>\n  <div>\n    <h5>My Card</h5>\n  </div>\n</div>",
            "expectedOutput": "",
            "validationType": "containsAll",
            "validationValue": [
                "card",
                "card-body",
                "card-title",
                "My Card"
            ],
            "hint": "Add class=\"card\", class=\"card-body\", class=\"card-title\" to the respective elements.",
            "solutionCode": "<div class=\"row\">\n  <div class=\"col-6\">Half</div>\n  <div class=\"col-6\">Half</div>\n</div>"
        },
        {
            "id": 6,
            "title": "Navbar",
