            "hint": "echo $name . \"\\n\"; echo $version;",
            "solutionCode": "<?php $x = 10; $y = 5; echo $x + $y; ?>"
        },
        {
            "id": 3,
            "title": "If-Else",
            "difficulty": "basic",
            "description": "Given <code>$age = 20</code>, print <strong>Adult</strong> if >= 18, else <strong>Minor</strong>.",
            "starterCode": "<?php\n$age = 20;\n// Write if-else\n?>",
            "expectedOutput": "Adult",
            "validationType": "outputContains",
            "validationValue": "Adult",
            "hint": "if ($age >= 18) { echo \"Adult\"; }",
            "solutionCode": "<?php $n = 4; if ($n % 2 == 0) echo 'Even'; else echo 'Odd'; ?>"
        },
        {
            "id": 4,
            "title": "For Loop",
            "difficulty": "basic",
            "description": "Print numbers <strong>1 to 5</strong> using a for loop.",
            "starterCode": "<?php\n// Print 1 to 5\n?>",
            "expectedOutput": "1",
            "validationType": "outputContainsAll",
            "validationValue": [
                "1",
                "2",
                "3",
                "4",
                "5"
            ],
            "hint": "for ($i = 1; $i <= 5; $i++) { echo $i . \"\\n\"; }",
            "solutionCode": "<?php for ($i = 1; $i <= 5; $i++) echo $i . '\\n'; ?>"
        },
        {
