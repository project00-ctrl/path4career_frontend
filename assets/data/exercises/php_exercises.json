                "Apple",
                "Banana",
                "Cherry"
            ],
            "hint": "foreach ($fruits as $f) { echo $f . \"\\n\"; }",
            "solutionCode": "<?php $arr = [1, 2, 3, 4, 5]; echo array_sum($arr); ?>"
