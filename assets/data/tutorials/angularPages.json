[
  {
    "title": "Angular Intro",
    "content": "<h1>Angular Introduction</h1><div class=\"page-nav-buttons\"><button class=\"btn-secondary prev-btn\" disabled>❮ Home</button><button class=\"btn-primary next-btn\">Next ❯</button></div><div class=\"content-section\"><h3>What is Angular?</h3><p class=\"text-block\">Angular is a TypeScript-based framework developed by Google for building web applications.</p></div><div class=\"content-section\"><h3>Why Use Angular?</h3><ul class=\"feature-list\"><li><strong>Component-based</strong> - Reusable UI components</li><li><strong>TypeScript</strong> - Type-safe development</li><li><strong>Dependency Injection</strong> - Better architecture</li><li><strong>Two-way Binding</strong> - Automatic sync</li></ul></div><div class=\"page-nav-buttons bottom-nav\"><button class=\"btn-secondary prev-btn\" disabled>❮ Home</button><button class=\"btn-primary next-btn\">Next ❯</button></div>"
  },
  {
    "title": "Angular Installation",
    "content": "<h1>Angular Installation</h1><div class=\"page-nav-buttons\"><button class=\"btn-secondary prev-btn\">❮ Previous</button><button class=\"btn-primary next-btn\">Next ❯</button></div><div class=\"content-section\"><h3>Installing Angular CLI</h3><p class=\"text-block\">Angular CLI is the official tool for creating and managing Angular projects.</p></div><div class=\"syntax-wrapper\"><div class=\"syntax-header\">Install CLI</div><div class=\"code-editor\"><pre>npm install -g @angular/cli</pre></div><button class=\"btn-try-it\" style=\"margin: 0 0 15px 15px;\">Try it Yourself »</button><div class=\"syntax-wrapper\"><div class=\"syntax-header\">Check Version</div><div class=\"code-editor\"><pre>ng version</pre></div><button class=\"btn-try-it\" style=\"margin: 0 0 15px 15px;\">Try it Yourself »</button><div class=\"page-nav-buttons bottom-nav\"><button class=\"btn-secondary prev-btn\">❮ Previous</button><button class=\"btn-primary next-btn\">Next ❯</button></div>"
  },
  {
    "title": "Angular First App",
    "content": "<h1>Your First Angular App</h1><div class=\"page-nav-buttons\"><button class=\"btn-secondary prev-btn\">❮ Previous</button><button class=\"btn-primary next-btn\">Next ❯</button></div><div class=\"syntax-wrapper\"><div class=\"syntax-header\">Create Project</div><div class=\"code-editor\"><pre>ng new my-app<br>cd my-app<br>ng serve</pre></div><button class=\"btn-try-it\" style=\"margin: 0 0 15px 15px;\">Try it Yourself »</button><div class=\"content-section\"><h3>Project Structure</h3><ul class=\"feature-list\"><li><strong>src/app</strong> - Application code</li><li><strong>angular.json</strong> - Configuration</li><li><strong>package.json</strong> - Dependencies</li></ul></div><div class=\"page-nav-buttons bottom-nav\"><button class=\"btn-secondary prev-btn\">❮ Previous</button><button class=\"btn-primary next-btn\">Next ❯</button></div>"
  },
  {
    "title": "Angular Components",
    "content": "<h1>Angular Components</h1><div class=\"page-nav-buttons\"><button class=\"btn-secondary prev-btn\">❮ Previous</button><button class=\"btn-primary next-btn\">Next ❯</button></div><div class=\"content-section\"><h3>What is a Component?</h3><p class=\"text-block\">Components are the building blocks of Angular applications.</p></div><div class=\"syntax-wrapper\"><div class=\"syntax-header\">Generate Component</div><div class=\"code-editor\"><pre>ng generate component my-component</pre></div><button class=\"btn-try-it\" style=\"margin: 0 0 15px 15px;\">Try it Yourself »</button><div class=\"syntax-wrapper\"><div class=\"syntax-header\">Component TS</div><div class=\"code-editor\"><pre>import { Component } from '@angular/core';\n@Component({\n  selector: 'app-my-component',\n  templateUrl: './my-component.component.html'\n})\nexport class MyComponentComponent {\n  title = 'Hello Angular!';\n}</pre></div><button class=\"btn-try-it\" style=\"margin: 0 0 15px 15px;\">Try it Yourself »</button><div class=\"syntax-wrapper\"><div class=\"syntax-header\">Component HTML</div><div class=\"code-editor\"><pre><h1>{{ title }}</h1></pre></div><button class=\"btn-try-it\" style=\"margin: 0 0 15px 15px;\">Try it Yourself »</button><div class=\"page-nav-buttons bottom-nav\"><button class=\"btn-secondary prev-btn\">❮ Previous</button><button class=\"btn-primary next-btn\">Next ❯</button></div>"
  },
  {
    "title": "Angular Templates",
    "content": "<h1>Angular Templates</h1><div class=\"page-nav-buttons\"><button class=\"btn-secondary prev-btn\">❮ Previous</button><button class=\"btn-primary next-btn\">Next ❯</button></div><div class=\"content-section\"><h3>Template Syntax</h3><div class=\"syntax-wrapper\"><div class=\"syntax-header\">Interpolation</div><div class=\"code-editor\"><pre><p>Hello, {{ name }}!</p><br><p>2 + 2 = {{ 2 + 2 }}</p></pre></div><button class=\"btn-try-it\" style=\"margin: 0 0 15px 15px;\">Try it Yourself »</button></div><div class=\"content-section\"><h3>Property Binding</h3><div class=\"syntax-wrapper\"><div class=\"syntax-header\">Example</div><div class=\"code-editor\"><pre><img [src]=\"imageUrl\"><br><button [disabled]=\"isDisabled\">Click</button></pre></div><button class=\"btn-try-it\" style=\"margin: 0 0 15px 15px;\">Try it Yourself »</button></div><div class=\"content-section\"><h3>Event Binding</h3><div class=\"syntax-wrapper\"><div class=\"syntax-header\">Example</div><div class=\"code-editor\"><pre><button (click)=\"onClick()\">Click Me</button></pre></div><button class=\"btn-try-it\" style=\"margin: 0 0 15px 15px;\">Try it Yourself »</button></div><div class=\"page-nav-buttons bottom-nav\"><button class=\"btn-secondary prev-btn\">❮ Previous</button><button class=\"btn-primary next-btn\">Next ❯</button></div>"
  },
  {
    "title": "Angular Directives",
    "content": "<h1>Angular Directives</h1><div class=\"page-nav-buttons\"><button class=\"btn-secondary prev-btn\">❮ Previous</button><button class=\"btn-primary next-btn\">Next ❯</button></div><div class=\"content-section\"><h3>Built-in Directives</h3><div class=\"syntax-wrapper\"><div class=\"syntax-header\">ngIf</div><div class=\"code-editor\"><pre><div *ngIf=\"isLoggedIn\">Welcome!</div></pre></div><button class=\"btn-try-it\" style=\"margin: 0 0 15px 15px;\">Try it Yourself »</button><div class=\"syntax-wrapper\"><div class=\"syntax-header\">ngFor</div><div class=\"code-editor\"><pre><ul>\n  <li *ngFor=\"let item of items\">{{ item }}</li>\n</ul></pre></div><button class=\"btn-try-it\" style=\"margin: 0 0 15px 15px;\">Try it Yourself »</button><div class=\"syntax-wrapper\"><div class=\"syntax-header\">ngClass</div><div class=\"code-editor\"><pre><div [ngClass]=\"{'active': isActive}\">Content</div></pre></div><button class=\"btn-try-it\" style=\"margin: 0 0 15px 15px;\">Try it Yourself »</button><div class=\"content-section\"><h3>Custom Directive</h3><div class=\"syntax-wrapper\"><div class=\"syntax-header\">Generate</div><div class=\"code-editor\"><pre>ng generate directive my-directive</pre></div><button class=\"btn-try-it\" style=\"margin: 0 0 15px 15px;\">Try it Yourself »</button></div><div class=\"page-nav-buttons bottom-nav\"><button class=\"btn-secondary prev-btn\">❮ Previous</button><button class=\"btn-primary next-btn\">Next ❯</button></div>"
  },
  {
    "title": "Angular Data Binding",
    "content": "<h1>Angular Data Binding</h1><div class=\"page-nav-buttons\"><button class=\"btn-secondary prev-btn\">❮ Previous</button><button class=\"btn-primary next-btn\">Next ❯</button></div><div class=\"content-section\"><h3>One-way Binding</h3><div class=\"syntax-wrapper\"><div class=\"syntax-header\">Interpolation</div><div class=\"code-editor\"><pre>{{ title }}</pre></div><button class=\"btn-try-it\" style=\"margin: 0 0 15px 15px;\">Try it Yourself »</button><div class=\"syntax-wrapper\"><div class=\"syntax-header\">Property</div><div class=\"code-editor\"><pre>[property]=\"value\"</pre></div><button class=\"btn-try-it\" style=\"margin: 0 0 15px 15px;\">Try it Yourself »</button></div><div class=\"content-section\"><h3>Two-way Binding</h3><div class=\"syntax-wrapper\"><div class=\"syntax-header\">ngModel</div><div class=\"code-editor\"><pre><input [(ngModel)]=\"username\"><br><p>Hello {{ username }}!</p></pre></div><button class=\"btn-try-it\" style=\"margin: 0 0 15px 15px;\">Try it Yourself »</button></div><div class=\"content-section\"><h3>Event Binding</h3><div class=\"syntax-wrapper\"><div class=\"syntax-header\">Example</div><div class=\"code-editor\"><pre>(click)=\"handleClick()\"<br>(keyup)=\"onKeyUp($event)\"</pre></div><button class=\"btn-try-it\" style=\"margin: 0 0 15px 15px;\">Try it Yourself »</button></div><div class=\"page-nav-buttons bottom-nav\"><button class=\"btn-secondary prev-btn\">❮ Previous</button><button class=\"btn-primary next-btn\">Next ❯</button></div>"
  },
  {
    "title": "Angular Services",
    "content": "<h1>Angular Services</h1><div class=\"page-nav-buttons\"><button class=\"btn-secondary prev-btn\">❮ Previous</button><button class=\"btn-primary next-btn\">Next ❯</button></div><div class=\"content-section\"><h3>What is a Service?</h3><p class=\"text-block\">Services are singleton objects that contain shared logic and data.</p></div><div class=\"syntax-wrapper\"><div class=\"syntax-header\">Generate Service</div><div class=\"code-editor\"><pre>ng generate service data</pre></div><button class=\"btn-try-it\" style=\"margin: 0 0 15px 15px;\">Try it Yourself »</button><div class=\"syntax-wrapper\"><div class=\"syntax-header\">Service TS</div><div class=\"code-editor\"><pre>import { Injectable } from '@angular/core';\n@Injectable({\n  providedIn: 'root'\n})\nexport class DataService {\n  getData() {\n    return ['Item 1', 'Item 2', 'Item 3'];\n  }\n}</pre></div><button class=\"btn-try-it\" style=\"margin: 0 0 15px 15px;\">Try it Yourself »</button><div class=\"syntax-wrapper\"><div class=\"syntax-header\">Use in Component</div><div class=\"code-editor\"><pre>import { DataService } from './data.service';\nconstructor(private dataService: DataService) {}\nngOnInit() {\n  this.items = this.dataService.getData();\n}</pre></div><button class=\"btn-try-it\" style=\"margin: 0 0 15px 15px;\">Try it Yourself »</button><div class=\"page-nav-buttons bottom-nav\"><button class=\"btn-secondary prev-btn\">❮ Previous</button><button class=\"btn-primary next-btn\">Next ❯</button></div>"
  },
  {
    "title": "Angular HTTP",
    "content": "<h1>Angular HTTP</h1><div class=\"page-nav-buttons\"><button class=\"btn-secondary prev-btn\">❮ Previous</button><button class=\"btn-primary next-btn\">Next ❯</button></div><div class=\"content-section\"><h3>HTTP Client</h3><div class=\"syntax-wrapper\"><div class=\"syntax-header\">Setup</div><div class=\"code-editor\"><pre>import { HttpClientModule } from '@angular/common/http';\n@NgModule({\n  imports: [HttpClientModule]\n})\nexport class AppModule {}</pre></div><button class=\"btn-try-it\" style=\"margin: 0 0 15px 15px;\">Try it Yourself »</button></div><div class=\"syntax-wrapper\"><div class=\"syntax-header\">GET Request</div><div class=\"code-editor\"><pre>import { HttpClient } from '@angular/common/http';\nconstructor(private http: HttpClient) {}\ngetUsers() {\n  return this.http.get('/api/users');\n}</pre></div><button class=\"btn-try-it\" style=\"margin: 0 0 15px 15px;\">Try it Yourself »</button></div><div class=\"content-section\"><h3>HTTP Methods</h3><div class=\"syntax-wrapper\"><div class=\"syntax-header\">All Methods</div><div class=\"code-editor\"><pre>this.http.get(url);\nthis.http.post(url, data);\nthis.http.put(url, data);\nthis.http.delete(url);</pre></div><button class=\"btn-try-it\" style=\"margin: 0 0 15px 15px;\">Try it Yourself »</button></div><div class=\"page-nav-buttons bottom-nav\"><button class=\"btn-secondary prev-btn\">❮ Previous</button><button class=\"btn-primary next-btn\">Next ❯</button></div>"
  },
  {
    "title": "Angular Routing",
    "content": "<h1>Angular Routing</h1><div class=\"page-nav-buttons\"><button class=\"btn-secondary prev-btn\">❮ Previous</button><button class=\"btn-primary next-btn\">Next ❯</button></div><div class=\"content-section\"><h3>Setting Up Routes</h3><div class=\"syntax-wrapper\"><div class=\"syntax-header\">app-routing.module.ts</div><div class=\"code-editor\"><pre>import { RouterModule, Routes } from '@angular/router';\nconst routes: Routes = [\n  { path: '', component: HomeComponent },\n  { path: 'about', component: AboutComponent },\n  { path: '**', component: NotFoundComponent }\n];</pre></div><button class=\"btn-try-it\" style=\"margin: 0 0 15px 15px;\">Try it Yourself »</button></div><div class=\"syntax-wrapper\"><div class=\"syntax-header\">Router Outlet</div><div class=\"code-editor\"><pre><router-outlet></router-outlet></pre></div><button class=\"btn-try-it\" style=\"margin: 0 0 15px 15px;\">Try it Yourself »</button><div class=\"syntax-wrapper\"><div class=\"syntax-header\">Navigation</div><div class=\"code-editor\"><pre><a routerLink=\"/about\">About</a><br><button (click)=\"goHome()\">Home</button></pre></div><button class=\"btn-try-it\" style=\"margin: 0 0 15px 15px;\">Try it Yourself »</button><div class=\"page-nav-buttons bottom-nav\"><button class=\"btn-secondary prev-btn\">❮ Previous</button><button class=\"btn-primary next-btn\">Next ❯</button></div>"
  },
  {
    "title": "Angular Forms",
    "content": "<h1>Angular Forms</h1><div class=\"page-nav-buttons\"><button class=\"btn-secondary prev-btn\">❮ Previous</button><button class=\"btn-primary next-btn\">Next ❯</button></div><div class=\"content-section\"><h3>Template-driven Forms</h3><div class=\"syntax-wrapper\"><div class=\"syntax-header\">HTML</div><div class=\"code-editor\"><pre><form #myForm=\"ngForm\" (ngSubmit)=\"onSubmit(myForm)\">\n  <input name=\"username\" ngModel>\n  <button type=\"submit\">Submit</button>\n</form></pre></div><button class=\"btn-try-it\" style=\"margin: 0 0 15px 15px;\">Try it Yourself »</button></div><div class=\"content-section\"><h3>Reactive Forms</h3><div class=\"syntax-wrapper\"><div class=\"syntax-header\">TS</div><div class=\"code-editor\"><pre>import { FormBuilder, FormGroup } from '@angular/forms';\nform: FormGroup;\nconstructor(private fb: FormBuilder) {\n  this.form = this.fb.group({\n    username: [''],\n    email: ['']\n  });\n}</pre></div><button class=\"btn-try-it\" style=\"margin: 0 0 15px 15px;\">Try it Yourself »</button><div class=\"syntax-wrapper\"><div class=\"syntax-header\">HTML</div><div class=\"code-editor\"><pre><form [formGroup]=\"form\">\n  <input formControlName=\"username\">\n</form></pre></div><button class=\"btn-try-it\" style=\"margin: 0 0 15px 15px;\">Try it Yourself »</button><div class=\"page-nav-buttons bottom-nav\"><button class=\"btn-secondary prev-btn\">❮ Previous</button><button class=\"btn-primary next-btn\">Next ❯</button></div>"
  },
  {
    "title": "Angular Pipes",
    "content": "<h1>Angular Pipes</h1><div class=\"page-nav-buttons\"><button class=\"btn-secondary prev-btn\">❮ Previous</button><button class=\"btn-primary next-btn\">Next ❯</button></div><div class=\"content-section\"><h3>Built-in Pipes</h3><div class=\"syntax-wrapper\"><div class=\"syntax-header\">Examples</div><div class=\"code-editor\"><pre>{{ name | uppercase }}<br>{{ price | currency }}<br>{{ date | date:'short' }}<br>{{ number | number:'1.2-2' }}</pre></div><button class=\"btn-try-it\" style=\"margin: 0 0 15px 15px;\">Try it Yourself »</button></div><div class=\"content-section\"><h3>Custom Pipe</h3><div class=\"syntax-wrapper\"><div class=\"syntax-header\">Generate</div><div class=\"code-editor\"><pre>ng generate pipe my-pipe</pre></div><button class=\"btn-try-it\" style=\"margin: 0 0 15px 15px;\">Try it Yourself »</button><div class=\"syntax-wrapper\"><div class=\"syntax-header\">Pipe TS</div><div class=\"code-editor\"><pre>import { Pipe, PipeTransform } from '@angular/core';\n@Pipe({ name: 'myPipe' })\nexport class MyPipePipe implements PipeTransform {\n  transform(value: string): string {\n    return value.toUpperCase();\n  }\n}</pre></div><button class=\"btn-try-it\" style=\"margin: 0 0 15px 15px;\">Try it Yourself »</button><div class=\"page-nav-buttons bottom-nav\"><button class=\"btn-secondary prev-btn\">❮ Previous</button><button class=\"btn-primary next-btn\">Next ❯</button></div>"
  },
  {
    "title": "Angular Modules",
    "content": "<h1>Angular Modules</h1><div class=\"page-nav-buttons\"><button class=\"btn-secondary prev-btn\">❮ Previous</button><button class=\"btn-primary next-btn\">Next ❯</button></div><div class=\"content-section\"><h3>NgModule</h3><div class=\"syntax-wrapper\"><div class=\"syntax-header\">Example</div><div class=\"code-editor\"><pre>import { NgModule } from '@angular/core';\nimport { BrowserModule } from '@angular/platform-browser';\n@NgModule({\n  declarations: [AppComponent],\n  imports: [BrowserModule],\n  providers: [],\n  bootstrap: [AppComponent]\n})\nexport class AppModule {}</pre></div><button class=\"btn-try-it\" style=\"margin: 0 0 15px 15px;\">Try it Yourself »</button></div><div class=\"content-section\"><h3>Feature Modules</h3><div class=\"syntax-wrapper\"><div class=\"syntax-header\">Generate</div><div class=\"code-editor\"><pre>ng generate module my-module</pre></div><button class=\"btn-try-it\" style=\"margin: 0 0 15px 15px;\">Try it Yourself »</button><div class=\"syntax-wrapper\"><div class=\"syntax-header\">Lazy Load</div><div class=\"code-editor\"><pre>{ path: 'feature', <br>  loadChildren: () => import('./feature/feature.module')<br>    .then(m => m.FeatureModule) }</pre></div><button class=\"btn-try-it\" style=\"margin: 0 0 15px 15px;\">Try it Yourself »</button><div class=\"page-nav-buttons bottom-nav\"><button class=\"btn-secondary prev-btn\">❮ Previous</button><button class=\"btn-primary next-btn\">Next ❯</button></div>"
  },
  {
    "title": "Angular Dependency Injection",
    "content": "<h1>Angular Dependency Injection</h1><div class=\"page-nav-buttons\"><button class=\"btn-secondary prev-btn\">❮ Previous</button><button class=\"btn-primary next-btn\">Next ❯</button></div><div class=\"content-section\"><h3>What is DI?</h3><p class=\"text-block\">Dependency Injection is a design pattern where dependencies are provided rather than created.</p></div><div class=\"syntax-wrapper\"><div class=\"syntax-header\">Constructor Injection</div><div class=\"code-editor\"><pre>constructor(private service: MyService) {}<br>// or<br>constructor(@Inject(MyService) private service) {}</pre></div><button class=\"btn-try-it\" style=\"margin: 0 0 15px 15px;\">Try it Yourself »</button></div><div class=\"content-section\"><h3>Providers</h3><div class=\"syntax-wrapper\"><div class=\"syntax-header\">Types</div><div class=\"code-editor\"><pre>// Service (singleton)<br>{ provideIn: 'root' }<br>// Component level<br>{ provide: MyService, useClass: MyService }<br>// Value<br>{ provide: API_URL, useValue: 'http://api.com' }</pre></div><button class=\"btn-try-it\" style=\"margin: 0 0 15px 15px;\">Try it Yourself »</button></div><div class=\"page-nav-buttons bottom-nav\"><button class=\"btn-secondary prev-btn\">❮ Previous</button><button class=\"btn-primary next-btn\">Next ❯</button></div>"
  },
  {
    "title": "Angular Lifecycle",
    "content": "<h1>Angular Lifecycle Hooks</h1><div class=\"page-nav-buttons\"><button class=\"btn-secondary prev-btn\">❮ Previous</button><button class=\"btn-primary next-btn\">Next ❯</button></div><div class=\"content-section\"><h3>Lifecycle Hooks</h3><div class=\"syntax-wrapper\"><div class=\"syntax-header\">Example</div><div class=\"code-editor\"><pre>import { Component, OnInit, OnDestroy } from '@angular/core';\nexport class MyComponent implements OnInit, OnDestroy {\n  ngOnInit() {\n    console.log('Component initialized');\n  }\n  ngOnDestroy() {\n    console.log('Component destroyed');\n  }\n}</pre></div><button class=\"btn-try-it\" style=\"margin: 0 0 15px 15px;\">Try it Yourself »</button></div><div class=\"content-section\"><h3>Other Hooks</h3><ul class=\"feature-list\"><li><strong>ngOnChanges</strong> - When input changes</li><li><strong>ngDoCheck</strong> - Custom change detection</li><li><strong>ngAfterViewInit</strong> - After view initializes</li><li><strong>ngAfterContentInit</strong> - After content initializes</li></ul></div><div class=\"page-nav-buttons bottom-nav\"><button class=\"btn-secondary prev-btn\">❮ Previous</button><button class=\"btn-primary next-btn\">Next ❯</button></div>"
  },
  {
    "title": "Angular Observables",
    "content": "<h1>Angular Observables</h1><div class=\"page-nav-buttons\"><button class=\"btn-secondary prev-btn\">❮ Previous</button><button class=\"btn-primary next-btn\">Next ❯</button></div><div class=\"content-section\"><h3>RxJS Observables</h3><div class=\"syntax-wrapper\"><div class=\"syntax-header\">Create</div><div class=\"code-editor\"><pre>import { Observable } from 'rxjs';\nconst obs = new Observable(observer => {\n  observer.next('Hello');\n  observer.complete();\n});</pre></div><button class=\"btn-try-it\" style=\"margin: 0 0 15px 15px;\">Try it Yourself »</button></div><div class=\"content-section\"><h3>Subscription</h3><div class=\"syntax-wrapper\"><div class=\"syntax-header\">Subscribe</div><div class=\"code-editor\"><pre>obs.subscribe({\n  next: data => console.log(data),\n  error: err => console.error(err),\n  complete: () => console.log('Done')\n});</pre></div><button class=\"btn-try-it\" style=\"margin: 0 0 15px 15px;\">Try it Yourself »</button></div><div class=\"content-section\"><h3>Operators</h3><div class=\"syntax-wrapper\"><div class=\"syntax-header\">Common</div><div class=\"code-editor\"><pre>import { map, filter } from 'rxjs/operators';\ndata$.pipe(\n  filter(item => item.active),\n  map(item => item.name)\n).subscribe();</pre></div><button class=\"btn-try-it\" style=\"margin: 0 0 15px 15px;\">Try it Yourself »</button></div><div class=\"page-nav-buttons bottom-nav\"><button class=\"btn-secondary prev-btn\">❮ Previous</button><button class=\"btn-primary next-btn\">Next ❯</button></div>"
  },
  {
    "title": "Angular Signals",
    "content": "<h1>Angular Signals</h1><div class=\"page-nav-buttons\"><button class=\"btn-secondary prev-btn\">❮ Previous</button><button class=\"btn-primary next-btn\">Next ❯</button></div><div class=\"content-section\"><h3>What are Signals?</h3><p class=\"text-block\">Signals are a new reactive primitive in Angular for fine-grained reactivity.</p></div><div class=\"syntax-wrapper\"><div class=\"syntax-header\">Create Signal</div><div class=\"code-editor\"><pre>import { signal, computed } from '@angular/core';\nconst count = signal(0);\nconst doubled = computed(() => count() * 2);</pre></div><button class=\"btn-try-it\" style=\"margin: 0 0 15px 15px;\">Try it Yourself »</button></div><div class=\"syntax-wrapper\"><div class=\"syntax-header\">Update</div><div class=\"code-editor\"><pre>count.set(5);\ncount.update(c => c + 1);</pre></div><button class=\"btn-try-it\" style=\"margin: 0 0 15px 15px;\">Try it Yourself »</button><div class=\"syntax-wrapper\"><div class=\"syntax-header\">In Template</div><div class=\"code-editor\"><pre><p>Count: {{ count() }}</p><br><p>Doubled: {{ doubled() }}</p></pre></div><button class=\"btn-try-it\" style=\"margin: 0 0 15px 15px;\">Try it Yourself »</button><div class=\"page-nav-buttons bottom-nav\"><button class=\"btn-secondary prev-btn\">❮ Previous</button><button class=\"btn-primary next-btn\">Next ❯</button></div>"
  },
  {
    "title": "Angular Testing",
    "content": "<h1>Angular Testing</h1><div class=\"page-nav-buttons\"><button class=\"btn-secondary prev-btn\">❮ Previous</button><button class=\"btn-primary next-btn\">Next ❯</button></div><div class=\"content-section\"><h3>Unit Testing</h3><div class=\"syntax-wrapper\"><div class=\"syntax-header\">Component Test</div><div class=\"code-editor\"><pre>import { ComponentFixture, TestBed } from '@angular/core/testing';\nimport { MyComponent } from './my.component';\ndescribe('MyComponent', () => {\n  let component: MyComponent;\n  let fixture: ComponentFixture<MyComponent>;\n  beforeEach(async () => {\n    await TestBed.configureTestingModule({\n      declarations: [ MyComponent ]\n    }).compileComponents();\n    fixture = TestBed.createComponent(MyComponent);\n    component = fixture.componentInstance;\n    fixture.detectChanges();\n  });\n  it('should create', () => {\n    expect(component).toBeTruthy();\n  });\n});</pre></div><button class=\"btn-try-it\" style=\"margin: 0 0 15px 15px;\">Try it Yourself »</button></div><div class=\"content-section\"><h3>Run Tests</h3><div class=\"syntax-wrapper\"><div class=\"syntax-header\">Commands</div><div class=\"code-editor\"><pre>ng test<br>ng test --code-coverage</pre></div><button class=\"btn-try-it\" style=\"margin: 0 0 15px 15px;\">Try it Yourself »</button></div><div class=\"page-nav-buttons bottom-nav\"><button class=\"btn-secondary prev-btn\">❮ Previous</button><button class=\"btn-primary next-btn\">Next ❯</button></div>"
  },
  {
    "title": "Angular SSR",
    "content": "<h1>Angular SSR & Angular Universal</h1><div class=\"page-nav-buttons\"><button class=\"btn-secondary prev-btn\">❮ Previous</button><button class=\"btn-primary next-btn\">Next ❯</button></div><div class=\"content-section\"><h3>Server-Side Rendering</h3><p class=\"text-block\">SSR improves performance and SEO for Angular applications.</p></div><div class=\"syntax-wrapper\"><div class=\"syntax-header\">Add SSR</div><div class=\"code-editor\"><pre>ng add @angular/ssr</pre></div><button class=\"btn-try-it\" style=\"margin: 0 0 15px 15px;\">Try it Yourself »</button></div><div class=\"content-section\"><h3>Benefits</h3><ul class=\"feature-list\"><li><strong>SEO</strong> - Better search engine indexing</li><li><strong>Performance</strong> - Faster first contentful paint</li><li><strong>Social Sharing</strong> - Preview cards work properly</li></ul></div><div class=\"page-nav-buttons bottom-nav\"><button class=\"btn-secondary prev-btn\">❮ Previous</button><button class=\"btn-primary next-btn\">Next ❯</button></div>"
